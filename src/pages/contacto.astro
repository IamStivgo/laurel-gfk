---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';

const waUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMsg)}`;
---

<BaseLayout
  title="Contacto y comisiones · Laurel.gfk"
  description="Escríbeme para comisiones de mural, retratos, ilustraciones y cursos. Respondo en menos de 48 horas."
  active="contacto"
>
  <slot name="head" slot="head">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "Contacto · Laurel.gfk",
      "url": "https://laurelgfk.com/contacto",
      "mainEntity": {
        "@type": "Person",
        "name": "Laurel.gfk",
        "url": "https://laurelgfk.com",
        "sameAs": ["https://www.instagram.com/laurel.gfk"]
      }
    }
    </script>
  </slot>

  <!-- Header -->
  <section class="page-head reveal">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Inicio</a>
        <span>/</span>
        <span>Contacto</span>
      </div>
      <h1 class="h-display">Hablemos <em>juntxs</em>.</h1>
    </div>
  </section>

  <!-- Formulario + info -->
  <section style="padding-top:0;" class="reveal">
    <div class="container">
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:clamp(32px,5vw,80px); align-items:start;">

        <!-- Formulario Netlify -->
        <div>
          <div class="kicker">Formulario de contacto</div>
          <h2 class="h-section" style="margin-bottom:32px;">
            Cuéntame tu <em>proyecto</em>.
          </h2>

          <form
            name="contacto"
            method="POST"
            action="/gracias"
            data-netlify="true"
            data-netlify-honeypot="bot-field"
            style="display:flex; flex-direction:column; gap:20px;"
          >
            <!-- Honeypot -->
            <input type="hidden" name="form-name" value="contacto" />
            <p style="display:none;">
              <label>No llenes esto: <input name="bot-field" /></label>
            </p>

            <!-- Nombre -->
            <div style="display:flex; flex-direction:column; gap:6px;">
              <label for="nombre" style="font-family:var(--mono); font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute);">Nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                placeholder="Tu nombre"
                style="padding:12px 16px; border:1px solid var(--line-strong); border-radius:var(--radius); font-family:var(--body); font-size:16px; background:var(--paper); color:var(--ink); outline:none; transition:border-color 0.15s;"
              />
            </div>

            <!-- Email -->
            <div style="display:flex; flex-direction:column; gap:6px;">
              <label for="email" style="font-family:var(--mono); font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute);">Email *</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="hola@ejemplo.com"
                style="padding:12px 16px; border:1px solid var(--line-strong); border-radius:var(--radius); font-family:var(--body); font-size:16px; background:var(--paper); color:var(--ink); outline:none; transition:border-color 0.15s;"
              />
            </div>

            <!-- Tipo de proyecto -->
            <div style="display:flex; flex-direction:column; gap:6px;">
              <label for="tipo" style="font-family:var(--mono); font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute);">¿Qué tipo de proyecto?</label>
              <select
                id="tipo"
                name="tipo"
                style="padding:12px 16px; border:1px solid var(--line-strong); border-radius:var(--radius); font-family:var(--body); font-size:16px; background:var(--paper); color:var(--ink); outline:none; cursor:pointer;"
              >
                <option value="">Selecciona una opción</option>
                <option value="mural">Mural</option>
                <option value="retrato">Retrato o ilustración</option>
                <option value="graffiti">Graffiti / lettering</option>
                <option value="curso">Curso o taller</option>
                <option value="curaduría">Curaduría o gestión</option>
                <option value="otro">Otro</option>
              </select>
            </div>

            <!-- Mensaje -->
            <div style="display:flex; flex-direction:column; gap:6px;">
              <label for="mensaje" style="font-family:var(--mono); font-size:11px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute);">Mensaje *</label>
              <textarea
                id="mensaje"
                name="mensaje"
                required
                rows="5"
                placeholder="Cuéntame tu idea: espacio, tamaño, fechas, referencias, presupuesto aproximado..."
                style="padding:12px 16px; border:1px solid var(--line-strong); border-radius:var(--radius); font-family:var(--body); font-size:16px; background:var(--paper); color:var(--ink); outline:none; resize:vertical; min-height:140px; transition:border-color 0.15s;"
              ></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="align-self:flex-start; padding:16px 28px;">
              Enviar mensaje →
            </button>
          </form>
        </div>

        <!-- Info de contacto -->
        <div style="position:sticky; top:96px;">
          <div class="kicker">O escríbeme directo</div>
          <h2 class="h-section" style="font-size:clamp(28px,3.5vw,48px); margin-bottom:32px;">
            La forma más rápida es <em>WhatsApp</em>.
          </h2>

          <a
            href={waUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-primary"
            style="margin-bottom:32px; width:100%; justify-content:center;"
          >
            Escribir por WhatsApp ↗
          </a>

          <!-- Links -->
          <div style="display:flex; flex-direction:column; gap:0;">
            {[
              { label: 'Instagram', href: SITE.instagram, val: '@laurel.gfk' },
              { label: 'Linktree', href: SITE.linktree, val: 'linktr.ee/laurel.gfk' },
              { label: 'WhatsApp', href: waUrl, val: `+${SITE.whatsapp.slice(0,2)} ${SITE.whatsapp.slice(2)}` },
              { label: 'Ubicación', href: '#', val: SITE.location },
            ].map(({ label, href, val }) => (
              <div style="display:flex; justify-content:space-between; align-items:center; padding:14px 0; border-bottom:1px solid var(--line);">
                <span style="font-family:var(--mono); font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute);">{label}</span>
                <a href={href} target={href !== '#' ? '_blank' : undefined} rel="noopener noreferrer"
                  style="font-weight:600; color:var(--ink); font-size:14.5px;">
                  {val}
                </a>
              </div>
            ))}
          </div>

          <!-- Tiempo de respuesta -->
          <div style="margin-top:28px; padding:20px; background:var(--paper-2); border-radius:var(--radius-lg);">
            <div style="font-family:var(--mono); font-size:10.5px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-mute); margin-bottom:8px;">Tiempo de respuesta</div>
            <p style="margin:0; font-size:15px; color:var(--ink-soft);">
              Respondo en menos de 48 horas. Bogotá, Colombia (UTC−5).
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  input:focus, textarea:focus, select:focus {
    border-color: var(--violet) !important;
    box-shadow: 0 0 0 3px rgba(61, 46, 110, 0.1);
  }
</style>
