---
import '../styles/global.css';
import { SITE } from '../config/site';
import Nav from '../components/ui/Nav.astro';
import Footer from '../components/ui/Footer.astro';
import WhatsAppFAB from '../components/ui/WhatsAppFAB.astro';
import Reveal from '../components/ui/Reveal.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  canonical?: string;
  active?: 'inicio' | 'obra' | 'productos' | 'cursos' | 'blog' | 'contacto';
  author?: string;
}

const {
  title,
  description = SITE.description,
  image = '/og-default.jpg',
  imageAlt = `${SITE.name} — Arte, murales y cursos en Bogotá`,
  noindex = false,
  canonical,
  active,
  author = SITE.name,
} = Astro.props;

const canonicalURL = canonical ?? new URL(Astro.url.pathname, SITE.url).href;
const ogImage = new URL(image, SITE.url).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Anti-FOUC: aplica el tema ANTES de pintar cualquier pixel -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = (stored === 'light' || stored === 'dark')
            ? stored
            : (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>

    <!-- theme-color dinámico (claro / oscuro) -->
    <meta name="theme-color" content="#F4EFE6" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#15102A" media="(prefers-color-scheme: dark)" />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content={SITE.name} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@laurelgfk" />
    <meta name="twitter:creator" content="@laurelgfk" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <!-- Favicon + PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- RSS Blog -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Blog`}
      href={`${SITE.url}/rss.xml`}
    />

    <!-- DNS prefetch para servicios externos -->
    <link rel="dns-prefetch" href="https://wa.me" />

    <!-- Preload de fuentes críticas (hero + body above-fold) -->
    <link rel="preload" href="/fonts/fraunces-latin-opsz-normal.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Slot para schemas JSON-LD o meta adicional por página -->
    <slot name="head" />
  </head>
  <body>
    <!-- Skip link para teclado / lectores de pantalla -->
    <a href="#main" class="skip-link">Saltar al contenido principal</a>
    <Nav active={active} />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppFAB />
    <Reveal />

    <!-- Vercel Analytics + Speed Insights -->
    <Analytics />
    <SpeedInsights />

    <!-- Custom events: WhatsApp FAB, cotización, Instagram, contacto -->
    <script>
      import { track } from '@vercel/analytics';

      document.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const anchor = target.closest('a');
        if (!anchor) return;

        const href = anchor.getAttribute('href') ?? '';

        // WhatsApp FAB o cualquier link a wa.me
        if (href.includes('wa.me')) {
          track('whatsapp_click', { source: anchor.classList.contains('wa-fab') ? 'fab' : 'inline' });
        }
        // Botones de cotización / comisión
        else if (anchor.classList.contains('nav-cta') || anchor.textContent?.toLowerCase().includes('cotiz') || anchor.textContent?.toLowerCase().includes('comis')) {
          track('cotizacion_click');
        }
        // Instagram
        else if (href.includes('instagram.com')) {
          track('instagram_click');
        }
        // Linktree
        else if (href.includes('linktr.ee')) {
          track('linktree_click');
        }
      });

      // Submit del formulario de contacto
      const form = document.querySelector('form[name="contacto"]');
      form?.addEventListener('submit', () => {
        track('contacto_submit');
      });
    </script>
  </body>
</html>
