---
import { SITE } from '../../config/site';

const waUrl = `https://wa.me/${SITE.whatsapp}?text=${encodeURIComponent(SITE.whatsappMsg)}`;
---

<a
  class="wa-fab"
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Escríbeme por WhatsApp"
>
  <span class="pulse" aria-hidden="true"></span>
  <span class="wa-tip">¡Escríbeme!</span>
  <!-- WhatsApp icon -->
  <svg viewBox="0 0 32 32" fill="currentColor" aria-hidden="true">
    <path d="M16.001 0.001C7.165 0.001 0.001 7.164 0.001 16c0 2.823 0.737 5.583 2.142 8.013L0 32l8.215-2.151C10.557 31.171 13.246 31.999 16 31.999c8.835 0 16-7.163 16-16C32 7.164 24.835 0.001 16.001 0.001zM16 29.318c-2.482 0-4.91-0.668-7.04-1.935l-0.504-0.298-5.224 1.369 1.391-5.090-0.327-0.519c-1.394-2.222-2.133-4.79-2.133-7.428C2.163 8.357 8.357 2.163 16 2.163c7.643 0 13.837 6.194 13.837 13.837 0 7.643-6.194 13.318-13.837 13.318zM23.503 19.013c-0.413-0.207-2.443-1.205-2.821-1.343-0.378-0.138-0.654-0.207-0.930 0.207s-1.067 1.343-1.308 1.619c-0.241 0.276-0.482 0.31-0.895 0.103-2.443-1.222-4.046-2.181-5.659-4.949-0.428-0.737 0.428-0.685 1.224-2.279 0.138-0.276 0.069-0.516-0.034-0.723-0.103-0.207-0.930-2.243-1.274-3.069-0.336-0.806-0.678-0.697-0.930-0.71-0.241-0.012-0.516-0.014-0.792-0.014s-0.723 0.103-1.101 0.516c-0.378 0.413-1.445 1.411-1.445 3.443s1.479 3.995 1.685 4.271c0.207 0.276 2.91 4.444 7.052 6.232 2.628 1.137 3.658 1.233 4.972 1.038 0.801-0.119 2.443-0.998 2.787-1.962s0.344-1.789 0.241-1.962c-0.103-0.172-0.378-0.276-0.792-0.482z"/>
