---
// ThemeToggle.astro — Botón sol/luna con persistencia en localStorage
---

<button
  id="theme-toggle"
  class="theme-toggle"
  aria-label="Cambiar a modo oscuro"
  title="Cambiar tema"
  type="button"
>
  <!-- Sol: visible en modo claro -->
  <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
  </svg>
  <!-- Luna: visible en modo oscuro -->
  <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--line-strong);
    color: var(--ink-soft);
    background: transparent;
    cursor: pointer;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    background: var(--paper-2);
    color: var(--ink);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--violet);
    outline-offset: 2px;
  }

  /* Solo el icono del tema contrario (lo que vas a cambiar) */
  .icon-moon { display: none; }

  [data-theme="dark"] .icon-sun  { display: none; }
  [data-theme="dark"] .icon-moon { display: block; }
</style>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    function updateLabel() {
      const isDark = document.documentElement.dataset.theme === 'dark';
      btn!.setAttribute('aria-label', isDark ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
    }

    btn.addEventListener('click', () => {
      const isDark = document.documentElement.dataset.theme === 'dark';
      const next = isDark ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      try { localStorage.setItem('theme', next); } catch (e) {}
      updateLabel();
    });

    updateLabel();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initThemeToggle);
  } else {
    initThemeToggle();
  }
</script>
